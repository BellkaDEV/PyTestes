// Funcao pra calcular a emissao do carro baseada na distancia e consumo
export const calcCarro = (dist: number, cons: number) => {
  return (dist / cons) * 0.82;
};

// Funcao pra calcular a emissao do onibus
export const calcOnibus = (dist: number) => {
  return dist * 0.03;
};
